# Frontend Environment Variables
# Copy this to .env and update for production

# API URL - Direct backend connection
# For local dev: http://localhost:3001
# For Pi (no Docker): http://localhost:3001
# For Pi (with Docker/nginx): http://localhost (proxied via nginx)
VITE_API_URL=http://localhost:3001

# Alternative: Use nginx proxy (no CORS issues)
# Uncomment for Docker/Production with nginx
# VITE_API_URL=/api
