---
import '../app/globals.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "keyPear - Cloud Storage", 
  description = "keyPear Cloud Storage Application" 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
