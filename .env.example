# Development Environment Setup
# Copy this file to .env and update the values

# ===========================================
# SERVER CONFIG
# ===========================================
PORT=3001
NODE_ENV=development

# ===========================================
# JWT SECRETS (generate with: openssl rand -base64 32)
# ===========================================
# Generate new secrets for production!
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# ===========================================
# DATABASE (SQLite - sql.js)
# ===========================================
# Database is stored in backend/data/keypear.db
# No configuration needed for local SQLite
DATABASE_URL=

# ===========================================
# STORAGE CONFIG - LOCAL or SMB
# ===========================================
# Option 1: Local storage (development)
STORAGE_PATH=./storage/user-files
THUMBNAIL_DIR=./storage/thumbnails
CHUNK_TEMP_DIR=./storage/chunks

# Option 2: SMB network storage (production on home network)
# Uncomment to use SMB instead of local storage
# SMB_SERVER=192.168.1.254
# SMB_SHARE=keypear-files
# SMB_USER=your-username
# SMB_PASSWORD=your-password
# SMB_MOUNT_PATH=/mnt/keypear-storage  # Local mount point on server
# SMB_MOUNT_IN_CONTAINER=/app/storage   # Path inside container

# ===========================================
# FRONTEND URL (for CORS & redirects)
# ===========================================
FRONTEND_URL=http://localhost:4321
PUBLIC_API_URL=http://localhost:3001

# ===========================================
# OAUTH (optional - skip to start without OAuth)
# ===========================================
# Get these from Google Cloud Console and GitHub Developer Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ===========================================
# MINIO (optional - alternative to SMB)
# ===========================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=keypear
MINIO_SECRET_KEY=change-me-in-production
MINIO_BUCKET=keypear-files

# ===========================================
# MONITORING (optional)
# ===========================================
PROMETHEUS_METRICS=true
GRAFANA_ADMIN=admin
GRAFANA_PASSWORD=admin

