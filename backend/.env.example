# KeyPear Backend Environment Variables
# Copy this to .env and fill in actual values

# Server
PORT=3001
NODE_ENV=development

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# SQLite Database
DATABASE_PATH=./data/keypear.db

# Storage Configuration
# SMB mount point (must be mounted before starting backend)
SMB_MOUNT_PATH=/home/pedroocalado/keypear_mount

# Files will be stored at: {SMB_MOUNT_PATH}/keypear_files/{userId}/{filename}
# Thumbnails at: ./storage/thumbnails/{fileId}.jpg

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Optional: OAuth (leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
