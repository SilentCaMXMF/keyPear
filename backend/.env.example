# KeyPear Backend Environment Variables
# Copy this to .env and fill in actual values

PORT=3001
NODE_ENV=development

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=keypear-dev-secret-change-in-production

# SQLite Database
DATABASE_PATH=./data/keypear.db

# Storage Configuration
# Use local storage (set SMB_MOUNT_PATH to empty to use local)
SMB_MOUNT_PATH=/home/pedroocalado/keypear_mount

# OR use local storage instead
LOCAL_STORAGE_PATH=/home/pedroocalado/keypear/storage

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
